{
  "name": "@gongyu/web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "build:production": "CLOUDFLARE_ENV=production react-router build",
    "cf-typegen": "wrangler types worker-configuration.d.ts",
    "cf-typegen:check": "wrangler types worker-configuration.d.ts --check",
    "check": "bun run typecheck && bun run build:production && wrangler deploy --config build/server/wrangler.json --dry-run",
    "deploy:production": "bun run build:production && wrangler deploy --config build/server/wrangler.json",
    "dev": "react-router dev",
    "migrate:production": "wrangler d1 migrations apply DB --remote --env production",
    "preview": "bun run build && vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:unit": "vitest run --project unit",
    "test:watch": "vitest",
    "test:workerd": "vitest run --project workerd",
    "typecheck": "bun run cf-typegen:check && react-router typegen && tsc -b"
  },
  "dependencies": {
    "@gongyu/auth": "workspace:*",
    "@gongyu/data": "workspace:*",
    "@gongyu/domain": "workspace:*",
    "@gongyu/integrations": "workspace:*",
    "@gongyu/jobs": "workspace:*",
    "@gongyu/ui": "workspace:*",
    "@mantine/core": "9.4.1",
    "@phosphor-icons/react": "2.1.10",
    "@simplewebauthn/browser": "13.3.0",
    "@simplewebauthn/server": "13.3.2",
    "effect": "4.0.0-beta.97",
    "isbot": "5.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "8.2.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.43.3",
    "@cloudflare/vitest-pool-workers": "0.18.4",
    "@effect/vitest": "4.0.0-beta.100",
    "@playwright/test": "1.61.1",
    "@react-router/dev": "8.2.0",
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wrangler": "4.109.0"
  }
}
