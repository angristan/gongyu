{
  "name": "@gongyu/jobs",
  "private": true,
  "type": "module",
  "exports": {
    "./data-workflow": "./src/data-workflow.ts",
    "./legacy-migration": "./src/legacy-migration.ts",
    "./outbox-dispatcher": "./src/outbox-dispatcher.ts",
    "./processor": "./src/processor.ts",
    "./runtime": "./src/runtime.ts",
    "./worker": "./src/worker.ts"
  },
  "scripts": {
    "cf-typegen": "wrangler types worker-configuration.d.ts --config ../web/wrangler.jsonc --include-env false",
    "cf-typegen:check": "wrangler types worker-configuration.d.ts --config ../web/wrangler.jsonc --include-env false --check",
    "check": "bun run typecheck",
    "migrate:legacy": "bun scripts/migrate-legacy.ts",
    "typecheck": "bun run cf-typegen:check && tsc -p tsconfig.json"
  },
  "dependencies": {
    "@gongyu/data": "workspace:*",
    "@gongyu/domain": "workspace:*",
    "@gongyu/integrations": "workspace:*",
    "effect": "4.0.0-beta.97"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "wrangler": "4.109.0"
  }
}
