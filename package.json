{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "gongyu",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --cwd apps/web build",
    "check": "bun run --cwd apps/web check && bun run --cwd apps/jobs check",
    "deploy:staging": "bun run migrate:staging && bun run --cwd apps/jobs deploy:staging && bun run --cwd apps/web deploy:staging",
    "dev": "bun run --cwd apps/web dev",
    "format": "bunx biome check --write .",
    "lint": "bunx biome check .",
    "migrate:staging": "bun run --cwd apps/jobs migrate:staging",
    "prepare": "[ -d .git ] && lefthook install || true",
    "test": "bun run --cwd apps/web test",
    "test:unit": "bun run --cwd apps/web test:unit",
    "test:watch": "bun run --cwd apps/web test:watch",
    "test:workerd": "bun run --cwd apps/web test:workerd",
    "typecheck": "bun run --cwd apps/web typecheck && bun run --cwd apps/jobs typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "lefthook": "2.1.10"
  }
}
